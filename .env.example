REDIS_HOST=localhost
REDIS_PORT=6379
PORT=3000

# Select one: ethereum | bnb | polygon | solana | ton
NETWORK=ethereum

# Required for EVM transaction history (Etherscan/BscScan/Polygonscan)
# Free key: https://etherscan.io/apis
ETHERSCAN_API_KEY=

# Required for token balances and NFTs via Moralis
# Free key: https://admin.moralis.io
MORALIS_API_KEY=

# Optional: override RPC URL for the selected network
# ETHEREUM_RPC_URL=https://eth.llamarpc.com
# BNB_RPC_URL=https://bsc-dataseed.binance.org
# POLYGON_RPC_URL=https://polygon-rpc.com

# Optional: tune Redis cache TTLs (seconds). Defaults shown.
# CACHE_TTL_BALANCE=30
# CACHE_TTL_TRANSACTIONS=60
# CACHE_TTL_TOKENS=120
# CACHE_TTL_NFTS=300
